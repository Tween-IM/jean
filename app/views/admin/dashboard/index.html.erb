<% content_for :title, "Dashboard — TMCP Admin" %>
<% content_for :page_title, "Dashboard" %>

<div class="max-w-7xl mx-auto px-6 py-8">
  <!-- Metric Cards -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Total Users</p>
      <p class="mt-2 text-3xl font-semibold text-gray-900 tracking-tight"><%= number_with_delimiter(@stats[:total_users]) %></p>
      <div class="mt-3 flex items-center gap-1.5">
        <span class="inline-flex items-center text-xs font-medium text-emerald-700 bg-emerald-50 px-2 py-0.5 rounded-full">
          <%= fluent_icon "checkmark", class: "w-3 h-3 mr-0.5" %>
          <%= number_with_delimiter(@stats[:active_users]) %> active
        </span>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Mini Apps</p>
      <p class="mt-2 text-3xl font-semibold text-gray-900 tracking-tight"><%= number_with_delimiter(@stats[:total_mini_apps]) %></p>
      <div class="mt-3 flex items-center gap-1.5">
        <span class="inline-flex items-center text-xs font-medium text-emerald-700 bg-emerald-50 px-2 py-0.5 rounded-full">
          <%= number_with_delimiter(@stats[:active_mini_apps]) %> active
        </span>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Installations</p>
      <p class="mt-2 text-3xl font-semibold text-gray-900 tracking-tight"><%= number_with_delimiter(@stats[:total_installations]) %></p>
      <div class="mt-3">
        <span class="text-xs text-gray-500">Across all mini-apps</span>
      </div>
    </div>

    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">OAuth Apps</p>
      <p class="mt-2 text-3xl font-semibold text-gray-900 tracking-tight"><%= number_with_delimiter(@stats[:total_oauth_apps]) %></p>
      <div class="mt-3">
        <span class="text-xs text-gray-500"><%= number_with_delimiter(@stats[:total_oauth_tokens]) %> active tokens</span>
      </div>
    </div>
  </div>

  <!-- Two Column: Recent Users + Recent Mini Apps -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <!-- Recent Users -->
    <div class="bg-white rounded-xl border border-gray-200">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <div>
          <h2 class="text-sm font-semibold text-gray-900">Recent Users</h2>
          <p class="text-xs text-gray-500 mt-0.5">Latest sign-ups on the platform</p>
        </div>
        <%= link_to admin_users_path, class: "text-xs font-medium text-indigo-600 hover:text-indigo-700 flex items-center gap-1" do %>
          View all <%= fluent_icon "chevron_right", class: "w-3 h-3" %>
        <% end %>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-50 text-xs font-medium text-gray-500 uppercase">
            <tr>
              <th class="px-5 py-3">User</th>
              <th class="px-5 py-3">Matrix ID</th>
              <th class="px-5 py-3">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @recent_users.each do |user| %>
              <tr class="hover:bg-gray-50/50 transition-colors">
                <td class="px-5 py-3 text-gray-900 font-medium"><%= user.matrix_username || user.matrix_user_id %></td>
                <td class="px-5 py-3 font-mono text-xs text-gray-600"><%= user.matrix_user_id %></td>
                <td class="px-5 py-3">
                  <% color = case user.status
                    when 'active' then 'bg-emerald-50 text-emerald-700'
                    when 'suspended' then 'bg-amber-50 text-amber-700'
                    when 'deactivated' then 'bg-gray-50 text-gray-700'
                    else 'bg-gray-50 text-gray-700'
                    end %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= color %>">
                    <%= user.status %>
                  </span>
                </td>
              </tr>
            <% end %>
            <% if @recent_users.empty? %>
              <tr>
                <td colspan="3" class="px-5 py-8 text-center text-sm text-gray-400">No users yet</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Recent Mini Apps -->
    <div class="bg-white rounded-xl border border-gray-200">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <div>
          <h2 class="text-sm font-semibold text-gray-900">Recent Mini Apps</h2>
          <p class="text-xs text-gray-500 mt-0.5">Latest app registrations</p>
        </div>
        <%= link_to admin_mini_apps_path, class: "text-xs font-medium text-indigo-600 hover:text-indigo-700 flex items-center gap-1" do %>
          View all <%= fluent_icon "chevron_right", class: "w-3 h-3" %>
        <% end %>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead class="bg-gray-50 text-xs font-medium text-gray-500 uppercase">
            <tr>
              <th class="px-5 py-3">Name</th>
              <th class="px-5 py-3">App ID</th>
              <th class="px-5 py-3">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @recent_mini_apps.each do |app| %>
              <tr class="hover:bg-gray-50/50 transition-colors">
                <td class="px-5 py-3 text-gray-900 font-medium"><%= app.name %></td>
                <td class="px-5 py-3 font-mono text-xs text-gray-600"><%= app.app_id %></td>
                <td class="px-5 py-3">
                  <% color = case app.status
                    when 'active' then 'bg-emerald-50 text-emerald-700'
                    when 'pending' then 'bg-amber-50 text-amber-700'
                    when 'rejected' then 'bg-red-50 text-red-700'
                    else 'bg-gray-50 text-gray-700'
                    end %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= color %>">
                    <%= app.status %>
                  </span>
                </td>
              </tr>
            <% end %>
            <% if @recent_mini_apps.empty? %>
              <tr>
                <td colspan="3" class="px-5 py-8 text-center text-sm text-gray-400">No mini apps yet</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Pending Approvals -->
  <div class="bg-white rounded-xl border border-gray-200">
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
      <div>
        <h2 class="text-sm font-semibold text-gray-900">Pending Approvals</h2>
        <p class="text-xs text-gray-500 mt-0.5">OAuth scope approvals awaiting admin review</p>
      </div>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead class="bg-gray-50 text-xs font-medium text-gray-500 uppercase">
          <tr>
            <th class="px-5 py-3">User</th>
            <th class="px-5 py-3">Mini App</th>
            <th class="px-5 py-3">Scope</th>
            <th class="px-5 py-3">Requested</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @pending_approvals.each do |approval| %>
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="px-5 py-3 text-gray-700"><%= approval.user&.matrix_user_id %></td>
              <td class="px-5 py-3 text-gray-700"><%= approval.miniapp&.name || approval.miniapp_id %></td>
              <td class="px-5 py-3">
                <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-indigo-50 text-indigo-700">
                  <%= approval.scope %>
                </span>
              </td>
              <td class="px-5 py-3 text-xs text-gray-500 whitespace-nowrap"><%= time_ago_in_words(approval.created_at) %> ago</td>
            </tr>
          <% end %>
          <% if @pending_approvals.empty? %>
            <tr>
              <td colspan="4" class="px-5 py-8 text-center text-sm text-gray-400">No pending approvals</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
