<div class="mb-8">
  <h1 class="text-3xl font-bold text-slate-900">Dashboard</h1>
  <p class="text-slate-500 mt-1">Overview of your TMCP server</p>
</div>

<!-- Stats Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
  <div class="bg-white rounded-xl shadow-sm p-6 border border-slate-200">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-slate-500">Total Users</p>
        <p class="text-3xl font-bold text-slate-900 mt-1"><%= number_with_delimiter(@stats[:total_users]) %></p>
      </div>
      <div class="w-12 h-12 bg-indigo-50 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
      </div>
    </div>
    <div class="mt-4 flex items-center text-sm">
      <span class="text-green-600 font-medium"><%= @stats[:active_users] %> active</span>
      <span class="text-slate-400 mx-2">·</span>
      <span class="text-red-600 font-medium"><%= @stats[:suspended_users] %> suspended</span>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm p-6 border border-slate-200">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-slate-500">Mini Apps</p>
        <p class="text-3xl font-bold text-slate-900 mt-1"><%= number_with_delimiter(@stats[:total_mini_apps]) %></p>
      </div>
      <div class="w-12 h-12 bg-emerald-50 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
      </div>
    </div>
    <div class="mt-4 text-sm text-green-600 font-medium">
      <%= @stats[:active_mini_apps] %> active
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm p-6 border border-slate-200">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-slate-500">Installations</p>
        <p class="text-3xl font-bold text-slate-900 mt-1"><%= number_with_delimiter(@stats[:total_installations]) %></p>
      </div>
      <div class="w-12 h-12 bg-amber-50 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11"/></svg>
      </div>
    </div>
    <div class="mt-4 text-sm text-slate-500">
      Across all mini-apps
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm p-6 border border-slate-200">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-slate-500">OAuth Apps</p>
        <p class="text-3xl font-bold text-slate-900 mt-1"><%= number_with_delimiter(@stats[:total_oauth_apps]) %></p>
      </div>
      <div class="w-12 h-12 bg-rose-50 rounded-lg flex items-center justify-center">
        <svg class="w-6 h-6 text-rose-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
      </div>
    </div>
    <div class="mt-4 text-sm text-slate-500">
      <%= number_with_delimiter(@stats[:total_oauth_tokens]) %> active tokens
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Recent Users -->
  <div class="bg-white rounded-xl shadow-sm border border-slate-200">
    <div class="p-6 border-b border-slate-100 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-slate-900">Recent Users</h2>
      <%= link_to "View all", admin_users_path, class: "text-sm text-indigo-600 hover:text-indigo-700 font-medium" %>
    </div>
    <div class="divide-y divide-slate-100">
      <% @recent_users.each do |user| %>
        <div class="p-4 flex items-center justify-between hover:bg-slate-50">
          <div>
            <p class="font-medium text-slate-900"><%= user.matrix_username || user.matrix_user_id %></p>
            <p class="text-sm text-slate-500"><%= user.wallet_id %></p>
          </div>
          <span class="px-2 py-1 text-xs font-medium rounded-full <%= user.active? ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
            <%= user.status %>
          </span>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent Mini Apps -->
  <div class="bg-white rounded-xl shadow-sm border border-slate-200">
    <div class="p-6 border-b border-slate-100 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-slate-900">Recent Mini Apps</h2>
      <%= link_to "View all", admin_mini_apps_path, class: "text-sm text-indigo-600 hover:text-indigo-700 font-medium" %>
    </div>
    <div class="divide-y divide-slate-100">
      <% @recent_mini_apps.each do |app| %>
        <div class="p-4 flex items-center justify-between hover:bg-slate-50">
          <div>
            <p class="font-medium text-slate-900"><%= app.name %></p>
            <p class="text-sm text-slate-500"><%= app.app_id %> · <%= app.classification %></p>
          </div>
          <span class="px-2 py-1 text-xs font-medium rounded-full <%= app.active? ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700' %>">
            <%= app.status %>
          </span>
        </div>
      <% end %>
    </div>
  </div>
</div>
