<% content_for :title, "Review Queue — TMCP Admin" %>

<div class="mb-6">
  <h1 class="text-xl font-semibold text-gray-900">Review Queue</h1>
  <p class="mt-1 text-sm text-gray-500">Mini-apps awaiting manual review</p>
</div>

<!-- Pending Reviews Section -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-slate-100">
    <h2 class="text-lg font-semibold text-slate-900">Pending Review (<%= @pending_apps.count %>)</h2>
    <p class="text-sm text-slate-500">Apps submitted for review, awaiting approval</p>
  </div>

  <% if @pending_apps.any? %>
    <div class="divide-y divide-slate-100">
      <% @pending_apps.each do |app| %>
        <div class="p-6 flex items-center justify-between hover:bg-slate-50">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3">
              <h3 class="text-sm font-medium text-slate-900 truncate"><%= app.name %></h3>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                <%= app.classification_label %>
              </span>
            </div>
            <p class="mt-1 text-xs text-slate-500"><%= app.app_id %> · v<%= app.version %></p>
            <p class="mt-1 text-xs text-slate-400">
              Submitted <%= app.submitted_at ? "#{time_ago_in_words(app.submitted_at)} ago" : "not yet submitted" %>
            </p>
          </div>

          <div class="flex items-center gap-3 ml-4">
            <%= link_to "Review", admin_mini_app_review_path(app),
                class: "px-4 py-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition-colors" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p class="mt-4 text-sm text-slate-500">No apps pending review</p>
    </div>
  <% end %>
</div>

<!-- Appeals Section -->
<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
  <div class="px-6 py-4 border-b border-slate-100">
    <h2 class="text-lg font-semibold text-slate-900">Appeals (<%= @appeals.count %>)</h2>
    <p class="text-sm text-slate-500">Rejection appeals requiring attention</p>
  </div>

  <% if @appeals.any? %>
    <div class="divide-y divide-slate-100">
      <% @appeals.each do |app| %>
        <div class="p-6 hover:bg-slate-50">
          <div class="flex items-start justify-between">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3">
                <h3 class="text-sm font-medium text-slate-900 truncate"><%= app.name %></h3>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                  Appeal
                </span>
              </div>
              <p class="mt-1 text-xs text-slate-500"><%= app.app_id %></p>
              <% if app.rejection_reason.present? %>
                <p class="mt-2 text-sm text-slate-600 bg-slate-50 p-3 rounded-lg">
                  Original rejection: <%= app.rejection_reason %>
                </p>
              <% end %>
            </div>

            <div class="flex items-center gap-2 ml-4">
              <%= button_to "Approve", resolve_mini_app_appeal_path(appeal_id: app.mini_app_appeals.first.id, approve: true),
                  method: :post,
                  class: "px-4 py-2 text-sm font-medium text-white bg-green-600 hover:bg-green-700 rounded-lg transition-colors" %>
              <%= button_to "Reject", resolve_mini_app_appeal_path(appeal_id: app.mini_app_appeals.first.id, approve: false),
                  method: :post,
                  class: "px-4 py-2 text-sm font-medium text-white bg-red-600 hover:bg-red-700 rounded-lg transition-colors" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="p-12 text-center">
      <svg class="mx-auto h-12 w-12 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p class="mt-4 text-sm text-slate-500">No pending appeals</p>
    </div>
  <% end %>
</div>