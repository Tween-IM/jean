<div class="mb-6">
  <%= link_to "← Back to User", admin_user_path(@user), class: "text-sm text-slate-500 hover:text-slate-700" %>
</div>

<div class="max-w-2xl">
  <h1 class="text-3xl font-bold text-slate-900 mb-6">Edit User</h1>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
    <%= form_with model: [:admin, @user], class: "space-y-6" do |f| %>
      <div>
        <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.select :status, User.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        <p class="mt-1 text-xs text-slate-500">Suspending a user will prevent them from using the platform.</p>
      </div>

      <div>
        <%= f.label :platform_role, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.select :platform_role, User.platform_roles.keys.map { |r| [r.humanize, r] }, {}, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        <p class="mt-1 text-xs text-slate-500">Changing the platform role grants or revokes admin access.</p>
      </div>

      <div class="flex items-center gap-3 pt-4">
        <%= f.submit "Save Changes", class: "bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg font-medium transition-colors cursor-pointer" %>
        <%= link_to "Cancel", admin_user_path(@user), class: "text-slate-600 hover:text-slate-800 font-medium" %>
      </div>
    <% end %>
  </div>
</div>
