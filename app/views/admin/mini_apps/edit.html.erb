<div class="mb-6">
  <%= link_to "← Back to Mini App", admin_mini_app_path(@mini_app), class: "text-sm text-slate-500 hover:text-slate-700" %>
</div>

<div class="max-w-2xl">
  <h1 class="text-3xl font-bold text-slate-900 mb-6">Edit Mini App</h1>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
    <%= form_with model: [:admin, @mini_app], class: "space-y-6" do |f| %>
      <div>
        <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :name, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <%= f.label :description, class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_area :description, rows: 4, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.select :status, MiniApp.statuses.keys.map { |s| [s.humanize, s] }, {}, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div>
          <%= f.label :classification, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.select :classification, MiniApp.classifications.keys.map { |c| [c.humanize, c] }, {}, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :version, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :version, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div>
          <%= f.label :developer_name, class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :developer_name, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
      </div>

      <div class="flex items-center gap-3 pt-4">
        <%= f.submit "Save Changes", class: "bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg font-medium transition-colors cursor-pointer" %>
        <%= link_to "Cancel", admin_mini_app_path(@mini_app), class: "text-slate-600 hover:text-slate-800 font-medium" %>
      </div>
    <% end %>
  </div>
</div>
