<div class="mb-6">
  <%= link_to "← Back to Mini Apps", admin_mini_apps_path, class: "text-sm text-slate-500 hover:text-slate-700" %>
</div>

<div class="max-w-2xl">
  <h1 class="text-3xl font-bold text-slate-900 mb-6">Create New Mini App</h1>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
    <%= form_with model: [:admin, @mini_app], local: true, html: { method: :post }, class: "space-y-6" do |f| %>
      <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">

      <div>
        <%= label_tag "mini_app[app_id]", "App ID", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= text_field_tag "mini_app[app_id]", @mini_app.app_id, placeholder: "ma_myapp",
            class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 font-mono" %>
        <p class="mt-1 text-xs text-slate-500">Must start with "ma_" followed by alphanumeric characters</p>
      </div>

      <div>
        <%= label_tag "mini_app[name]", "Name", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= text_field_tag "mini_app[name]", @mini_app.name, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <%= label_tag "mini_app[description]", "Description", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= text_area_tag "mini_app[description]", @mini_app.description, rows: 3, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= label_tag "mini_app[version]", "Version", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= text_field_tag "mini_app[version]", @mini_app.version || "1.0.0", class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div>
          <%= label_tag "mini_app[developer_name]", "Developer Name", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= text_field_tag "mini_app[developer_name]", @mini_app.developer_name, class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= label_tag "mini_app[classification]", "Classification", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= select_tag "mini_app[classification]", options_for_select(MiniApp.classifications.keys.map { |c| [c.humanize.titleize, c] }, @mini_app.classification || "community"), class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>

        <div>
          <%= label_tag "mini_app[status]", "Status", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= select_tag "mini_app[status]", options_for_select([["Pending Review", "pending_review"], ["Active", "active"], ["Draft", "draft"]], "pending_review"), class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        </div>
      </div>

      <div>
        <%= label_tag "mini_app[client_type]", "Client Type", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= select_tag "mini_app[client_type]", options_for_select([["Public", "public"], ["Confidential", "confidential"], ["Hybrid", "hybrid"]], "public"), class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div class="flex items-center gap-3 pt-4">
        <%= submit_tag "Create Mini App", class: "bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg font-medium transition-colors cursor-pointer" %>
        <%= link_to "Cancel", admin_mini_apps_path, class: "text-slate-600 hover:text-slate-800 font-medium" %>
      </div>
    <% end %>
  </div>
</div>