<div class="mb-6">
  <%= link_to "← Back to Mini Apps", admin_mini_apps_path, class: "text-sm text-slate-500 hover:text-slate-700" %>
</div>

<div class="mb-8 flex items-center justify-between">
  <div>
    <h1 class="text-3xl font-bold text-slate-900"><%= @mini_app.name %></h1>
    <p class="text-slate-500 mt-1"><%= @mini_app.app_id %></p>
  </div>
  <% if current_admin_user&.has_admin_permission?(:manage_mini_apps) %>
    <div class="flex gap-3">
      <%= link_to "Edit", edit_admin_mini_app_path(@mini_app), class: "bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg font-medium transition-colors" %>
    </div>
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <!-- Details -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
      <h2 class="text-lg font-semibold text-slate-900 mb-4">Details</h2>
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <dt class="text-sm font-medium text-slate-500">Name</dt>
          <dd class="mt-1 text-sm text-slate-900"><%= @mini_app.name %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-slate-500">App ID</dt>
          <dd class="mt-1 text-sm text-slate-900 font-mono"><%= @mini_app.app_id %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-slate-500">Developer</dt>
          <dd class="mt-1 text-sm text-slate-900"><%= @mini_app.developer_name || "—" %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-slate-500">Version</dt>
          <dd class="mt-1 text-sm text-slate-900"><%= @mini_app.version %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-slate-500">Status</dt>
          <dd class="mt-1">
            <span class="px-2 py-1 text-xs font-medium rounded-full <%= @mini_app.active? ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
              <%= @mini_app.status %>
            </span>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-slate-500">Classification</dt>
          <dd class="mt-1">
            <span class="px-2 py-1 text-xs font-medium rounded-full
              <%= case @mini_app.classification
                  when 'official' then 'bg-purple-100 text-purple-700'
                  when 'verified' then 'bg-blue-100 text-blue-700'
                  when 'community' then 'bg-green-100 text-green-700'
                  when 'beta' then 'bg-amber-100 text-amber-700'
                  else 'bg-slate-100 text-slate-700'
                  end %>">
              <%= @mini_app.classification %>
            </span>
          </dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-slate-500">Client Type</dt>
          <dd class="mt-1 text-sm text-slate-900"><%= @mini_app.client_type %></dd>
        </div>
        <div>
          <dt class="text-sm font-medium text-slate-500">Install Count</dt>
          <dd class="mt-1 text-sm text-slate-900"><%= number_with_delimiter(@mini_app.install_count) %></dd>
        </div>
      </dl>

      <% if @mini_app.description.present? %>
        <div class="mt-6">
          <dt class="text-sm font-medium text-slate-500">Description</dt>
          <dd class="mt-1 text-sm text-slate-900"><%= @mini_app.description %></dd>
        </div>
      <% end %>

      <% if @mini_app.manifest.present? %>
        <div class="mt-6">
          <dt class="text-sm font-medium text-slate-500">Manifest</dt>
          <dd class="mt-1">
            <pre class="bg-slate-50 p-3 rounded-lg text-xs text-slate-700 overflow-auto max-h-64"><%= JSON.pretty_generate(@mini_app.manifest) %></pre>
          </dd>
        </div>
      <% end %>
    </div>

    <!-- Installations -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
      <h2 class="text-lg font-semibold text-slate-900 mb-4">Recent Installations</h2>
      <% if @installations.any? %>
        <div class="divide-y divide-slate-100">
          <% @installations.each do |inst| %>
            <div class="py-3 flex items-center justify-between">
              <div>
                <p class="text-sm font-medium text-slate-900"><%= inst.user&.matrix_username || inst.user_id %></p>
                <p class="text-xs text-slate-500">Version <%= inst.version %> · <%= inst.status %></p>
              </div>
              <span class="text-xs text-slate-400"><%= time_ago_in_words(inst.created_at) %> ago</span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-slate-500 text-sm">No installations yet.</p>
      <% end %>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="space-y-6">
    <!-- Automated Check -->
    <% if @automated_check %>
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Automated Check</h2>
        <div class="space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-sm text-slate-600">HTTPS Only</span>
            <%= @automated_check.https_only ? "✅" : "❌" %>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-slate-600">CSP Valid</span>
            <%= @automated_check.csp_valid ? "✅" : "❌" %>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-slate-600">No Credentials</span>
            <%= @automated_check.no_credentials ? "✅" : "❌" %>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-slate-600">No Obfuscation</span>
            <%= @automated_check.no_obfuscation ? "✅" : "❌" %>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-slate-600">Dependency Scan</span>
            <%= @automated_check.dependency_scan_passed ? "✅" : "❌" %>
          </div>
        </div>
      </div>
    <% end %>

    <!-- Appeals -->
    <% if @appeals.any? %>
      <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-6">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">Appeals</h2>
        <div class="divide-y divide-slate-100">
          <% @appeals.each do |appeal| %>
            <div class="py-3">
              <p class="text-sm text-slate-900"><%= appeal.reason %></p>
              <p class="text-xs text-slate-500 mt-1"><%= appeal.status %> · <%= time_ago_in_words(appeal.created_at) %> ago</p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
