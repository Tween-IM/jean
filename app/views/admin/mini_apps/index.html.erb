<div class="mb-8">
  <h1 class="text-3xl font-bold text-slate-900">Mini Apps</h1>
  <p class="text-slate-500 mt-1">Manage mini-applications registered on the platform</p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
  <table class="min-w-full divide-y divide-slate-200">
    <thead class="bg-slate-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">App ID</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Classification</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Status</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Version</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Installs</th>
        <th class="px-6 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-slate-200">
      <% @mini_apps.records.each do |app| %>
        <tr class="hover:bg-slate-50">
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm font-medium text-slate-900"><%= app.name %></div>
            <div class="text-sm text-slate-500"><%= app.developer_name %></div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500 font-mono"><%= app.app_id %></td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="px-2 py-1 text-xs font-medium rounded-full
              <%= case app.classification
                  when 'official' then 'bg-purple-100 text-purple-700'
                  when 'verified' then 'bg-blue-100 text-blue-700'
                  when 'community' then 'bg-green-100 text-green-700'
                  when 'beta' then 'bg-amber-100 text-amber-700'
                  else 'bg-slate-100 text-slate-700'
                  end %>">
              <%= app.classification %>
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <span class="px-2 py-1 text-xs font-medium rounded-full <%= app.active? ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
              <%= app.status %>
            </span>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500"><%= app.version %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500"><%= number_with_delimiter(app.install_count) %></td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
            <%= link_to "View", admin_mini_app_path(app), class: "text-indigo-600 hover:text-indigo-900 mr-3" %>
            <% if current_admin_user&.has_admin_permission?(:manage_mini_apps) %>
              <%= link_to "Edit", edit_admin_mini_app_path(app), class: "text-indigo-600 hover:text-indigo-900" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= render "admin/shared/pagination", collection: @mini_apps %>
</div>
