<div class="min-h-screen flex items-center justify-center bg-slate-100">
  <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-slate-900">Two-Factor Authentication</h1>
      <p class="text-slate-500 mt-2">Enter the code from your authenticator app</p>
    </div>

    <%= form_with url: admin_mfa_path, method: :post, class: "space-y-6" do |f| %>
      <div>
        <%= f.label :mfa_code, "MFA Code", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :mfa_code, required: true, placeholder: "000000", autofocus: true,
            class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <%= f.submit "Verify", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-lg transition-colors cursor-pointer" %>
    <% end %>
  </div>
</div>
