<div class="min-h-screen flex items-center justify-center bg-slate-100">
  <div class="max-w-md w-full bg-white rounded-xl shadow-lg p-8">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-bold text-slate-900">TMCP Admin</h1>
      <p class="text-slate-500 mt-2">Sign in to access the admin panel</p>
    </div>

    <%= form_with url: admin_login_path, method: :post, class: "space-y-6" do |f| %>
      <div>
        <%= f.label :matrix_user_id, "Matrix User ID", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :matrix_user_id, required: true, placeholder: "@username:tween.im",
            class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <%= f.label :mfa_code, "MFA Code (if enabled)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :mfa_code, placeholder: "000000",
            class: "w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <%= f.submit "Sign In", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-4 rounded-lg transition-colors cursor-pointer" %>
    <% end %>

    <p class="mt-6 text-center text-xs text-slate-400">
      Authorized personnel only. Access is logged and audited.
    </p>
  </div>
</div>
