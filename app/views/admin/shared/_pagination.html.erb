<% if collection.total_pages > 1 %>
  <div class="px-6 py-4 border-t border-slate-200 flex items-center justify-between">
    <div class="text-sm text-slate-500">
      Showing <%= ((collection.current_page - 1) * collection.limit_value) + 1 %> -
      <%= [collection.current_page * collection.limit_value, collection.total_count].min %>
      of <%= collection.total_count %>
    </div>
    <div class="flex items-center gap-2">
      <% if collection.current_page > 1 %>
        <%= link_to "← Previous", url_for(page: collection.current_page - 1), class: "px-3 py-1 text-sm border border-slate-300 rounded-lg hover:bg-slate-50 text-slate-700" %>
      <% else %>
        <span class="px-3 py-1 text-sm border border-slate-200 rounded-lg text-slate-400 cursor-not-allowed">← Previous</span>
      <% end %>

      <span class="text-sm text-slate-600">
        Page <%= collection.current_page %> of <%= collection.total_pages %>
      </span>

      <% if collection.current_page < collection.total_pages %>
        <%= link_to "Next →", url_for(page: collection.current_page + 1), class: "px-3 py-1 text-sm border border-slate-300 rounded-lg hover:bg-slate-50 text-slate-700" %>
      <% else %>
        <span class="px-3 py-1 text-sm border border-slate-200 rounded-lg text-slate-400 cursor-not-allowed">Next →</span>
      <% end %>
    </div>
  </div>
<% end %>
