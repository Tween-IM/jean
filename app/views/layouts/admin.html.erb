<!DOCTYPE html>
<html>
  <head>
    <title>TMCP Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  </head>
  <body class="bg-slate-50 text-slate-900">
    <div class="min-h-screen flex">
      <!-- Sidebar -->
      <aside class="w-64 bg-slate-900 text-white flex flex-col">
        <div class="p-6 border-b border-slate-700">
          <h1 class="text-xl font-bold">TMCP Admin</h1>
          <p class="text-xs text-slate-400 mt-1">v1.0</p>
        </div>

        <nav class="flex-1 p-4 space-y-1">
          <%= link_to admin_dashboard_path, class: "flex items-center px-4 py-2 rounded-lg hover:bg-slate-800 #{current_page?(admin_dashboard_path) ? 'bg-slate-800' : ''}" do %>
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
            Dashboard
          <% end %>

          <%= link_to admin_mini_apps_path, class: "flex items-center px-4 py-2 rounded-lg hover:bg-slate-800 #{request.path.start_with?('/admin/mini-apps') ? 'bg-slate-800' : ''}" do %>
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            Mini Apps
          <% end %>

          <%= link_to admin_users_path, class: "flex items-center px-4 py-2 rounded-lg hover:bg-slate-800 #{request.path.start_with?('/admin/users') ? 'bg-slate-800' : ''}" do %>
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            Users
          <% end %>

          <%= link_to admin_oauth_applications_path, class: "flex items-center px-4 py-2 rounded-lg hover:bg-slate-800 #{request.path.start_with?('/admin/oauth') ? 'bg-slate-800' : ''}" do %>
            <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
            OAuth Apps
          <% end %>
        </nav>

        <div class="p-4 border-t border-slate-700">
          <div class="flex items-center justify-between">
            <div class="text-sm">
              <p class="font-medium"><%= current_admin_user&.matrix_username || "Unknown" %></p>
              <p class="text-slate-400 text-xs"><%= current_admin_user&.platform_role || "admin" %></p>
            </div>
            <%= button_to admin_logout_path, method: :delete, class: "text-slate-400 hover:text-white" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            <% end %>
          </div>
        </div>
      </aside>

      <!-- Main content -->
      <main class="flex-1 p-8 overflow-auto">
        <% if flash[:notice] %>
          <div class="mb-4 p-4 rounded-lg bg-green-50 border border-green-200 text-green-800">
            <%= flash[:notice] %>
          </div>
        <% end %>
        <% if flash[:alert] %>
          <div class="mb-4 p-4 rounded-lg bg-red-50 border border-red-200 text-red-800">
            <%= flash[:alert] %>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
